rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'rudoo6988@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidDeviceRegistration(data) {
      return data.keys().hasAll(['deviceId', 'timestamp']) &&
             data.keys().size() == 2 &&
             data.deviceId is string && data.deviceId.size() <= 128 &&
             data.timestamp == request.time;
    }

    // --- Collection Rules ---

    match /public_registrations/{deviceId} {
      allow get: if true;
      allow create: if isValidId(deviceId) && 
                      isValidDeviceRegistration(incoming()) &&
                      incoming().deviceId == deviceId &&
                      // Atomic counter update
                      (
                        (exists(/databases/$(database)/documents/stats/global) && 
                         getAfter(/databases/$(database)/documents/stats/global).data.count == get(/databases/$(database)/documents/stats/global).data.count + 1)
                        ||
                        (!exists(/databases/$(database)/documents/stats/global) && 
                         getAfter(/databases/$(database)/documents/stats/global).data.count == 1)
                      );
      allow update, delete: if false;
    }

    match /stats/global {
      allow read: if true;
      allow create: if incoming().count == 1 &&
                      existsAfter(/databases/$(database)/documents/public_registrations/$(incoming().initialDeviceId));
      allow update: if incoming().count == (existing().count + 1) &&
                      (
                        existsAfter(/databases/$(database)/documents/public_registrations/$(request.resource.data.lastDeviceId)) ||
                        isAdmin()
                      );
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
