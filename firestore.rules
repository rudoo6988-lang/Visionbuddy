rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'rudoo6988@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidSignup(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'timestamp']) &&
             data.keys().size() == 5 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.photoURL is string && data.photoURL.size() <= 1000 &&
             data.timestamp == request.time;
    }

    // --- Collection Rules ---

    match /waitlist/{signupId} {
      // Use UID as document ID to prevent duplicates
      allow get: if isSignedIn() && (signupId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && 
                      isEmailVerified() && 
                      isValidId(signupId) && 
                      signupId == request.auth.uid && 
                      isValidSignup(incoming());
                      
      allow update, delete: if false; // No modifications allowed after signup
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
