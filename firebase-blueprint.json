{
  "entities": {
    "Signup": {
      "title": "Signup",
      "description": "A user interest signup for the waitlist",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID of the user" },
        "email": { "type": "string", "format": "email", "description": "The email of the user" },
        "displayName": { "type": "string", "description": "The display name of the user" },
        "photoURL": { "type": "string", "description": "The profile image URL of the user" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the user signed up" }
      },
      "required": ["uid", "email", "displayName", "timestamp"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An admin user marker",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "The admin email" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/registrations/{signupId}": {
      "schema": "Signup",
      "description": "Collection of users interested in VisionBuddy"
    },
    "/stats/global": {
      "schema": {
        "type": "object",
        "properties": {
          "count": { "type": "number" }
        }
      },
      "description": "Global statistics for the project"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "White-listed admin users"
    }
  }
}
